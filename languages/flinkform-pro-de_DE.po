msgstr "Payload-Schlüssel für Feld \"%s\""

# --- Newsletter Panel (src/newsletter-panel.js) ---
#: src/newsletter-panel.js
msgid "Newsletter"
msgstr "Newsletter"

#: src/newsletter-panel.js
msgid "Subscribe to a newsletter list"
msgstr "In eine Newsletter-Liste eintragen"

#: src/newsletter-panel.js
msgid "Provider"
msgstr "Anbieter"

#: src/newsletter-panel.js
msgid "API credentials are configured under Flinkform → Newsletter."
msgstr "Die API-Zugangsdaten werden unter Flinkform > Newsletter konfiguriert."

#: src/newsletter-panel.js
msgid "List ID (number)"
msgstr "Listen-ID (Zahl)"

#: src/newsletter-panel.js
msgid "Audience ID"
msgstr "Audience-ID"

#: src/newsletter-panel.js
msgid "Group ID"
msgstr "Gruppen-ID"

#: src/newsletter-panel.js
msgid "List ID"
msgstr "Listen-ID"

#: src/newsletter-panel.js
msgid "Email field"
msgstr "E-Mail-Feld"

#: src/newsletter-panel.js
msgid "— Select the email field —"
msgstr "- E-Mail-Feld auswählen -"

#: src/newsletter-panel.js
msgid "Consent field (required)"
msgstr "Einwilligungsfeld (Pflicht)"

#: src/newsletter-panel.js
msgid "— Select the consent field —"
msgstr "- Einwilligungsfeld auswählen -"

#: src/newsletter-panel.js
msgid ""
"Visitors are only subscribed when they tick this field. Without a mapping, "
"nothing is ever sent — GDPR-safe by design."
msgstr ""
"Besucher werden nur eingetragen, wenn sie dieses Feld anhaken. Ohne "
"Zuordnung wird nichts gesendet - DSGVO-konform von Haus aus."

#: src/newsletter-panel.js
msgid ""
"No consent field mapped — signups are disabled. Add a Toggle or Consent "
"field (e.g. \"Subscribe me to the newsletter\") and select it above."
msgstr ""
"Kein Einwilligungsfeld zugeordnet - Anmeldungen sind deaktiviert. Fügen Sie "
"ein Toggle- oder Einwilligungsfeld hinzu (z. B. \"Mich zum Newsletter "
"anmelden\") und wählen Sie es oben aus."

#: src/newsletter-panel.js
msgid "First name field (optional)"
msgstr "Vornamefeld (optional)"

#: src/newsletter-panel.js
msgid "Last name field (optional)"
msgstr "Nachnamefeld (optional)"

#: src/newsletter-panel.js
msgid "— None —"
msgstr "- Keines -"

#: src/newsletter-panel.js
msgid "Double opt-in"
msgstr "Double-Opt-in"

#: src/newsletter-panel.js
msgid ""
"Sends the activation email of the DOI form configured under Flinkform → "
"Newsletter."
msgstr ""
"Sendet die Aktivierungs-E-Mail des DOI-Formulars, das unter Flinkform > "
"Newsletter konfiguriert ist."

#: src/newsletter-panel.js
msgid ""
"New contacts are created as \"pending\" and Mailchimp sends its confirmation "
"email."
msgstr ""
"Neue Kontakte werden als \"ausstehend\" erstellt und Mailchimp sendet seine "
"Bestätigungs-E-Mail."

#: src/newsletter-panel.js
msgid ""
"For Brevo, configure double opt-in inside Brevo (automation on list entry)."
msgstr ""
"Für Brevo konfigurieren Sie das Double-Opt-in direkt in Brevo (Automation "
"bei Listeneintrag)."

# --- File Upload Block (blocks/src/field-file/) ---
#: blocks/src/field-file/block.json
msgctxt "block title"
msgid "File Upload Field"
msgstr "Datei-Upload-Feld"

#: blocks/src/field-file/block.json
msgctxt "block description"
msgid "Let visitors attach a file to their submission (Pro)."
msgstr "Ermöglicht Besuchern, eine Datei an ihre Einsendung anzuhängen (Pro)."

#: blocks/src/field-file/edit.js
msgid "Field Settings"
msgstr "Feldeinstellungen"

#: blocks/src/field-file/edit.js
msgid "Required"
msgstr "Pflichtfeld"

#: blocks/src/field-file/edit.js
msgid "Help Text"
msgstr "Hilfetext"

#: blocks/src/field-file/edit.js
msgid "Field Name"
msgstr "Feldname"

#: blocks/src/field-file/edit.js
msgid "Key used in submission data. Auto-generated; change with care."
msgstr ""
"Schlüssel in den Einsendungsdaten. Wird automatisch generiert - nur mit "
"Bedacht ändern."

#: blocks/src/field-file/edit.js
msgid "Allowed Files"
msgstr "Erlaubte Dateien"

#: blocks/src/field-file/edit.js
msgid ""
"Select at least one file type — with none selected, every upload is rejected."
msgstr ""
"Wählen Sie mindestens einen Dateityp aus - ohne Auswahl wird jeder Upload "
"abgelehnt."

#: blocks/src/field-file/edit.js
msgid "Maximum size (MB)"
msgstr "Maximale Größe (MB)"

#: blocks/src/field-file/edit.js
msgid "Attach file to notification email"
msgstr "Datei an Benachrichtigungs-E-Mail anhängen"

#: blocks/src/field-file/edit.js
msgid ""
"The uploaded file is attached to the admin notification (up to 8 MB; larger "
"files arrive as a link). Combine with a Data Retention period on the form so "
"the server copy cleans itself up."
msgstr ""
"Die hochgeladene Datei wird an die Admin-Benachrichtigung angehängt (bis 8 "
"MB, größere Dateien kommen als Link). Kombinieren Sie dies mit einer "
"Datenspeicherungsfrist im Formular, damit die Serverkopie sich automatisch "
"bereinigt."

#: blocks/src/field-file/edit.js blocks/src/field-file/render.php
msgid "Choose a file"
msgstr "Datei auswählen"

#: blocks/src/field-file/edit.js blocks/src/field-file/render.php
msgid "or drag it here"
msgstr "oder hierher ziehen"

#: blocks/src/field-file/render.php
msgid "%s or drag it here"
msgstr "%s oder hierher ziehen"

#. translators: 1: allowed extensions list, 2: max size in MB
#: blocks/src/field-file/edit.js blocks/src/field-file/render.php
#, php-format
msgid "Allowed: %1$s · max. %2$d MB"
msgstr "Erlaubt: %1$s · max. %2$d MB"

#: blocks/src/field-file/edit.js
msgid "No file types allowed yet"
msgstr "Noch keine Dateitypen erlaubt"

#: blocks/src/field-file/render.php
msgid "Remove selected file"
msgstr "Ausgewählte Datei entfernen"

